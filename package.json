{
  "name": "reactjsesh",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:jsesh && tsc -b && vite build",
    "build:jsesh": "tsc -p tsconfig.jsesh.json",
